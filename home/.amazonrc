function newApp(){
  export AWS_REGION=us-east-1 && ./bin/medic-ops-tools app generate-template --stage prod --name $1
}

function onboardApp(){
  export AWS_REGION=us-east-1 && ./bin/medic-ops-tools app onboard --stage prod --name $1
}

